<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="EpubReader.Views.CalibreSettingsPage"
    xmlns:converter="clr-namespace:EpubReader.Converter"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    x:DataType="CalibreSettingsPageViewModel"
    x:TypeArguments="system:Boolean"
    BackgroundColor="{AppThemeBinding Dark={StaticResource AppBackgroundDarkColor},
                                      Light=White}"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <toolkit:Popup.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converter:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </toolkit:Popup.Resources>

    <Border
        Margin="8"
        Padding="12"
        BackgroundColor="{AppThemeBinding Dark={StaticResource AppBackgroundDarkColor},
                                          Light=White}"
        StrokeThickness="0">
        <ScrollView HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="16" WidthRequest="320">
                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="Calibre Settings" />
                    <Label
                        FontSize="12"
                        Opacity="0.75"
                        Text="Auto configuration is recommended. Switch to manual only if you need a specific Calibre server address." />
                </VerticalStackLayout>

                <Border Padding="12" StrokeThickness="1">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label FontAttributes="Bold" Text="Use auto configuration" />
                            <Label
                                FontSize="12"
                                Opacity="0.75"
                                Text="When enabled, EpubReader discovers your local Calibre server and stores the verified result." />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="1"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            IsToggled="{Binding IsAutoConfigEnabled}" />
                    </Grid>
                </Border>

                <VerticalStackLayout
                    IsVisible="{Binding IsManualAddressVisible}"
                    Spacing="6">
                    <Label FontAttributes="Bold" Text="Manual server address" />
                    <Entry
                        ClearButtonVisibility="WhileEditing"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Keyboard="Url"
                        Placeholder="http://192.168.1.10:8080"
                        ReturnType="Done"
                        Text="{Binding ManualServerAddress}" />
                    <Label
                        FontSize="12"
                        Opacity="0.75"
                        Text="Use the Calibre server root address only. Example: http://192.168.1.10:8080" />
                </VerticalStackLayout>

                <Label
                    FontSize="12"
                    IsVisible="{Binding SavedConfigurationSummary, Converter={StaticResource StringIsNotNullOrEmptyConverter}}"
                    Text="{Binding SavedConfigurationSummary}" />

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        VerticalOptions="Start" />
                    <Label
                        Grid.Column="1"
                        IsVisible="{Binding HasStatusMessage}"
                        LineBreakMode="WordWrap"
                        Text="{Binding StatusMessage}" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Text="Cancel" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding SaveSettingsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Text="Verify &amp; Save" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
