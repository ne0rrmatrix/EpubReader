<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="EpubReader.Views.FolderDialogePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:EpubReader.Models"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModel="clr-namespace:EpubReader.ViewModels"
    x:Name="CurrentPage"
    x:DataType="viewModel:FolderDialogPageViewModel"
    BackgroundColor="{AppThemeBinding Dark={StaticResource AppBackgroundDarkColor},
                                      Light=White}"
    Unloaded="CurrentPage_Unloaded">
    <Grid
        RowDefinitions="Auto,Auto,Auto,Auto,Auto"
        RowSpacing="10"
        WidthRequest="225">
        <Label
            Grid.Row="0"
            HeightRequest="75"
            HorizontalOptions="Center"
            Text="{Binding Text}"
            VerticalOptions="Start" />

        <Label
            Grid.Row="1"
            HorizontalOptions="Center"
            Text="{Binding CounterText}"
            VerticalOptions="Center" />

        <ProgressBar
            Grid.Row="2"
            Margin="12,8"
            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200},
                                              Dark={StaticResource Gray600}}"
            HorizontalOptions="FillAndExpand"
            Progress="{Binding Progress}"
            VerticalOptions="Center" />

        <Label
            Grid.Row="3"
            HorizontalOptions="Center"
            Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
            VerticalOptions="Center" />

        <Button
            Grid.Row="4"
            Command="{Binding Source={RelativeSource Mode=FindAncestorBindingContext, AncestorType={x:Type viewModel:FolderDialogPageViewModel}}, Path=CancelCommand}"
            HorizontalOptions="Center"
            Text="Cancel"
            VerticalOptions="End" />
    </Grid>
</toolkit:Popup>
