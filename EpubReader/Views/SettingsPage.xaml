<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="EpubReader.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:EpubReader.Models"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModel="clr-namespace:EpubReader.ViewModels"
    x:Name="CurrentPage"
    x:DataType="viewModel:SettingsPageViewModel"
    x:TypeArguments="system:Boolean"
    BackgroundColor="{AppThemeBinding Dark={StaticResource AppBackgroundDarkColor},
                                      Light=White}"
    CanBeDismissedByTappingOutsideOfPopup="True"
    HeightRequest="{OnPlatform WinUI=550,
                               Default=450}"
    Loaded="CurrentPage_Loaded"
    Unloaded="CurrentPage_Unloaded"
    WidthRequest="330">

    <ScrollView
        x:Name="ScrollView"
        HorizontalScrollBarVisibility="Never"
        VerticalScrollBarVisibility="Never">
        <Border
            Margin="5"
            Padding="5"
            Style="{StaticResource BorderGalleryCard}">
            <VerticalStackLayout
                x:Name="grid"
                Padding="0"
                Spacing="20">

                <!--  Reader Appearance Section  -->
                <StackLayout
                    Grid.Row="0"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Picker
                        x:Name="ThemePicker"
                        Title="Theme"
                        ItemDisplayBinding="{Binding Name, x:DataType=model:ColorScheme}"
                        ItemsSource="{Binding ColorSchemes}"
                        SelectedIndexChanged="ThemePicker_SelectedIndexChanged"
                        WidthRequest="250" />

                    <CollectionView
                        x:Name="ThemePreview"
                        HeightRequest="96"
                        ItemsLayout="HorizontalList"
                        ItemsSource="{Binding ColorSchemes}"
                        SelectionChanged="ThemePreview_SelectionChanged"
                        SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:ColorScheme">
                                <Border
                                    Margin="6"
                                    Padding="6"
                                    BackgroundColor="{Binding BackgroundColor}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 6">
                                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label
                                            FontSize="20"
                                            HorizontalOptions="Center"
                                            Text="Aa"
                                            TextColor="{Binding TextColor}" />
                                        <Label
                                            FontSize="11"
                                            HorizontalOptions="Center"
                                            Text="{Binding Name}"
                                            TextColor="{StaticResource Gray600}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>

                <StackLayout
                    Grid.Row="1"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Picker
                        x:Name="FontPicker"
                        Title="Select Font"
                        ItemDisplayBinding="{Binding FontFamily, x:DataType=model:EpubFonts}"
                        ItemsSource="{Binding Fonts}"
                        SelectedIndexChanged="FontPicker_SelectedIndexChanged"
                        WidthRequest="250" />

                    <Label
                        x:Name="FontPreview"
                        FontSize="16"
                        HorizontalOptions="Center"
                        LineBreakMode="NoWrap"
                        Text="The quick brown fox jumps over the lazy dog" />
                </StackLayout>

                <Label
                    Grid.Row="2"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    Text="Select Font Size" />

                <Slider
                    x:Name="FontSizeSlider"
                    Grid.Row="3"
                    Maximum="36"
                    Minimum="8"
                    ValueChanged="OnFontSizeSliderChanged"
                    WidthRequest="250" />

                <Label
                    x:Name="FontSizeLabel"
                    Grid.Row="4"
                    x:DataType="{x:Type Slider}"
                    HorizontalOptions="Center"
                    Text="{Binding Source={x:Reference FontSizeSlider}, Path=Value, StringFormat='Font Size: {0:F0}'}" />

                <StackLayout
                    Grid.Row="5"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Text="Line Spacing" />

                    <Picker
                        x:Name="LineSpacingPicker"
                        Title="Line Spacing"
                        SelectedIndexChanged="LineSpacingPicker_SelectedIndexChanged"
                        WidthRequest="250" />
                </StackLayout>

                <StackLayout
                    Grid.Row="6"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Text="Paragraph Spacing" />

                    <Picker
                        x:Name="ParagraphSpacingPicker"
                        Title="Paragraph Spacing"
                        SelectedIndexChanged="ParagraphSpacingPicker_SelectedIndexChanged"
                        WidthRequest="250" />
                </StackLayout>

                <StackLayout
                    Grid.Row="7"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Text="Text Alignment" />

                    <Picker
                        x:Name="TextAlignmentPicker"
                        Title="Text Alignment"
                        SelectedIndexChanged="TextAlignmentPicker_SelectedIndexChanged"
                        WidthRequest="250" />
                </StackLayout>

                <StackLayout
                    Grid.Row="8"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Text="Hyphenation" />

                    <Picker
                        x:Name="HyphenationPicker"
                        Title="Hyphenation"
                        SelectedIndexChanged="HyphenationPicker_SelectedIndexChanged"
                        WidthRequest="250" />
                </StackLayout>

                <StackLayout
                    Grid.Row="9"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Text="Letter Spacing" />

                    <Picker
                        x:Name="LetterSpacingPicker"
                        Title="Letter Spacing"
                        SelectedIndexChanged="LetterSpacingPicker_SelectedIndexChanged"
                        WidthRequest="250" />
                </StackLayout>

                <StackLayout
                    Grid.Row="10"
                    HorizontalOptions="Center"
                    Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Text="Word Spacing" />

                    <Picker
                        x:Name="WordSpacingPicker"
                        Title="Word Spacing"
                        SelectedIndexChanged="WordSpacingPicker_SelectedIndexChanged"
                        WidthRequest="250" />
                </StackLayout>

                <HorizontalStackLayout
                    x:Name="stackLayout"
                    Grid.Row="11"
                    HorizontalOptions="Center"
                    IsVisible="{OnPlatform WinUI=true,
                                           Default=false}"
                    Spacing="100"
                    WidthRequest="250">
                    <Label Text="Multiple Columns" VerticalOptions="Center" />
                    <Switch
                        x:Name="switchControl"
                        Toggled="switchControl_Toggled"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!--  Authentication Section  -->
                <Label
                    Grid.Row="12"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    Text="Account &amp; Sync" />

                <VerticalStackLayout Grid.Row="13" Spacing="10">

                    <!--  Auth Status Display  -->
                    <Label
                        FontSize="13"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding IsAuthenticated}"
                        LineBreakMode="WordWrap"
                        Text="{Binding AuthStatusText}"
                        TextColor="{AppThemeBinding Dark={StaticResource Gray300},
                                                    Light={StaticResource Gray600}}" />

                    <Label
                        FontSize="13"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding IsLocalOnly}"
                        Text="Local mode - No cloud sync"
                        TextColor="{AppThemeBinding Dark={StaticResource Gray400},
                                                    Light={StaticResource Gray600}}" />

                    <!--  Sign In Button (visible when not authenticated)  -->
                    <Button
                        BackgroundColor="{StaticResource NormalButtonBackgroundColor}"
                        Command="{Binding SignInCommand}"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        IsVisible="{Binding IsNotAuthenticated}"
                        Text="Sign In"
                        TextColor="{StaticResource NormalButtonTextColor}" />

                    <!--  Sign Out Button (visible when authenticated)  -->
                    <Button
                        BackgroundColor="{StaticResource NormalButtonBackgroundColor}"
                        Command="{Binding SignOutCommand}"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        IsVisible="{Binding IsAuthenticated}"
                        Text="Sign Out"
                        TextColor="{StaticResource NormalButtonTextColor}"
                        WidthRequest="200" />

                    <!--  Delete Cloud Data (visible when authenticated)  -->
                    <Button
                        BackgroundColor="{StaticResource NormalButtonBackgroundColor}"
                        Clicked="OnExportDataClicked"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        Text="Export Data"
                        TextColor="{StaticResource NormalButtonTextColor}"
                        WidthRequest="200" />

                    <Button
                        Grid.Row="9"
                        BackgroundColor="{StaticResource NormalButtonBackgroundColor}"
                        Clicked="OnPrivacyClicked"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        Text="Privacy Policy"
                        TextColor="{StaticResource NormalButtonTextColor}"
                        WidthRequest="200" />

                    <Button
                        Grid.Row="5"
                        BackgroundColor="{StaticResource NormalButtonBackgroundColor}"
                        Clicked="RemoveAllSettings"
                        HeightRequest="45"
                        Text="Restore Default Settings"
                        TextColor="{StaticResource NormalButtonTextColor}"
                        WidthRequest="200" />

                    <Button
                        BackgroundColor="{StaticResource Reset}"
                        BorderColor="{StaticResource Reset-Dark}"
                        Command="{Binding DeleteCloudDataCommand}"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        IsVisible="{Binding IsAuthenticated}"
                        Text="Delete Cloud Data"
                        TextColor="{StaticResource White}"
                        WidthRequest="200" />

                    <Button
                        BackgroundColor="{StaticResource Reset}"
                        BorderColor="{StaticResource Reset-Dark}"
                        Clicked="OnDeleteLocalDataClicked"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        Text="Delete Local Data"
                        TextColor="{StaticResource White}"
                        WidthRequest="200" />

                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </ScrollView>

</toolkit:Popup>
