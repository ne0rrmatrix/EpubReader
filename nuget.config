<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<!--To inherit the global NuGet package sources remove the <clear/> line below -->
		<clear />
		<add key="nuget" value="https://api.nuget.org/v3/index.json" />
		<add key="CommunityToolkitGitHubNuget" value="https://nuget.pkg.github.com/CommunityToolkit/index.json" />
        <!-- Optional personal GitHub Packages feed. Enable only when needed. -->
        <add key="ne0rrmatrixGitHubNuget" value="https://nuget.pkg.github.com/ne0rrmatrix/index.json" />
	</packageSources>
	<!-- CommunityToolkit GitHub Packages feed is added conditionally in CI
	     via the workflow when a valid NUGET_SECRET is present. -->
</configuration>
